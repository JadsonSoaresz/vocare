# ============================================================
# VOCARE — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA commite o .env no git
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Encontre em: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=sb_publishable_sua-chave-publica-aqui
SUPABASE_SERVICE_ROLE_KEY=sb_secret_sua-chave-service-role-aqui

# ── IA — configure apenas UMA opção ──────────────────────────
# Prioridade: ANTHROPIC_API_KEY → GOOGLE_AI_KEY → GROQ_API_KEY

# Groq (Gratuito, rápido) — https://console.groq.com/keys
GROQ_API_KEY=gsk_sua-chave-groq-aqui

# Google Gemini (Gratuito) — https://aistudio.google.com/app/apikey
# GOOGLE_AI_KEY=sua-chave-google-aqui

# Anthropic Claude (Pago, melhor qualidade) — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-api03-sua-chave-aqui

# ── App ──────────────────────────────────────────────────────
APP_URL=https://vocare.vercel.app
NODE_ENV=production
